    {
      "parameters": {
        "jsCode": "const weatherData = $input.first().json;\nconst ciudadData = $('Extraer mensaje').first().json;\nconst geoData = $('Extraer Coordenadas').first().json;\n\nconst ciudad = geoData.nombre ?? \"la ciudad consultada\";\nconst pais = geoData.pais ?? \"\";\nconst chatId = ciudadData.chatId;\n\nconst temp = weatherData.current_weather?.temperature ?? \"N/A\";\nconst viento = weatherData.current_weather?.windspeed ?? \"N/A\";\nconst codigo = weatherData.current_weather?.weathercode ?? \"N/A\";\n\nconst prompt = `\nEres un asistente de clima amigable. El usuario preguntó por el clima de ${ciudad}, ${pais}.\n\nDatos actuales:\n- Temperatura: ${temp}°C\n- Viento: ${viento} km/h\n- Código WMO: ${codigo}\n\nRedacta un mensaje corto en español con emojis para responder por Telegram. Máximo 3 líneas.\n`;\n\nreturn [{ json: { prompt, chatId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        80
      ],
      "id": "ac0d558f-1a5c-44d4-884d-44993a531794",
      "name": "Prompt mensaje clima"
    },
    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.output;\nconst ciudadData = $('Extraer mensaje').first().json;\n\nlet parsed;\ntry {\n  const clean = agentOutput.replace(/```json|```/g, \"\").trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  return [{ json: { sinMensaje: true } }];\n}\n\nif (!parsed.valida) {\n  return [{ json: { sinMensaje: true } }];\n}\n\nreturn [{ json: {\n  ciudad: parsed.ciudad,\n  chatId: ciudadData.chatId\n}}];"
      },
