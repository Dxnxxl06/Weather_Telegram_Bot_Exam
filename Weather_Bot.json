    {
      "parameters": {
        "jsCode": "const geoData = $input.first().json;\nconst ciudadData = $('Extraer mensaje').first().json;\n\nif (!geoData.results || geoData.results.length === 0) {\n  return [{ json: { sinMensaje: true } }];\n}\n\nconst lugar = geoData.results[0];\n\nreturn [{ json: {\n  lat: lugar.latitude,\n  lon: lugar.longitude,\n  nombre: lugar.name,\n  pais: lugar.country,\n  chatId: ciudadData.chatId\n}}];\n"
      },
